# Copy to .env.local and fill in a real token.

# Secret for the content write API (POST/PUT/DELETE on /api/*) and the CLI.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTENT_API_TOKEN=

# Where the carsonctl CLI sends requests. Defaults to http://localhost:3000.
CONTENT_API_URL=http://localhost:3000

# Optional: override the SQLite file location (defaults to ./data/content.db).
# CONTENT_DB_PATH=./data/content.db
